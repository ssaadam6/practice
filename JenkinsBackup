pipeline {
    agent none  

    triggers {
        cron('H 2 * * *')
    }

    stages {
        stage('Jenkins Backup') {
            steps {
                node('Controller') {  // Explicitly run on master
                    sh '''
                        mkdir -p /var/lib/jenkins/Jenkinsbackup
                        TIMESTAMP=$(date +%Y%m%d)
                        cp -r /var/lib/jenkins /var/lib/jenkins/Jenkinsbackup/jenkins_${TIMESTAMP}

                        # Remove backups older than 7 days
                        find /home/ubuntu/Jenkinsbackup -type d -name "jenkins_*" -mtime +7 -exec rm -rf {} + 2>/dev/null || true
                        
                        echo "Backup completed: jenkins_${TIMESTAMP}"
                    '''
                }
            }
        }
    }
}