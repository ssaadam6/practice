pipeline {
    agent { label 'Controller' }

    triggers {
        cron('35 18 * * *')
    }

    environment {
        BACKUP_SERVER = '172.31.36.153'
    }

    stages {
        stage('Sync to Backup') {
            steps {
                sshagent(['awsdevops']) {
                    sh '''
                        # Tell rsync to use ssh with no strict checking
                        rsync -avz --delete -e "ssh -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null" \
                            --exclude='workspace' \
                            --exclude='cache' \
                            /var/lib/jenkins/ \
                            ubuntu@$BACKUP_SERVER:/var/lib/jenkins/

                        # SSH to restart Jenkins
                        ssh -o StrictHostKeyChecking=no \
                            -o UserKnownHostsFile=/dev/null \
                            ubuntu@$BACKUP_SERVER \
                            "sudo systemctl restart jenkins"
                    '''
                }
            }
        }
    }
}