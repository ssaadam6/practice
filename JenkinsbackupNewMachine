pipeline {
    agent { label 'Controller' }

    triggers {
        cron('30 12 * * *')
    }

    environment {
        BACKUP_SERVER = '172.31.36.153'
    }

    stages {
        stage('Sync Jenkins') {
            steps {
                sshagent(['awsdevops']) {
                    sh '''
                        # Sync everything except workspace and cache
                        sudo rsync -avz --delete \
                            --exclude='workspace/' \
                            --exclude='cache/' \
                            /var/lib/jenkins/ \
                            ubuntu@$BACKUP_SERVER:/var/lib/jenkins/
                        
                        # Restart Jenkins to load new configs
                        ssh ubuntu@$BACKUP_SERVER "sudo systemctl restart jenkins"
                    '''
                }
            }
        }
    }
}